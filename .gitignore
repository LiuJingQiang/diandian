# Repository scope
# This repo tracks only the static frontend app, plus the GitHub Pages workflow
# required to deploy it. Everything else in the workspace stays local.
*

!/.gitignore
!/.github/
!/.github/workflows/
!/.github/workflows/pages.yml
!/game-frontend/
!/game-frontend/**

# Frontend dependencies and build output
game-frontend/node_modules/
game-frontend/dist/
game-frontend/.vite/

# Local/secrets
.DS_Store
game-frontend/.DS_Store
game-frontend/*.local.json
game-frontend/credentials.json
game-frontend/*.pem

# Tool screenshots / transient captures
game-frontend/*.png.tmp
game-frontend/*.snap
game-frontend/*.log
game-frontend/.playwright-mcp/
